---
import { client } from '../data/client';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title = 'Porozmawiajmy o ofercie',
  description = 'Opowiemy o dostępnych lokalach, terminach i warunkach.',
  buttonText = 'Napisz do nas',
  buttonHref = '/kontakt',
} = Astro.props;
---

<section class="relative overflow-hidden bg-dark py-20 sm:py-24 lg:py-28">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_80%_120%,color-mix(in_srgb,var(--color-primary-light)_35%,transparent),transparent_70%)]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-site px-4 sm:px-6">
    <div class="cta-rise mx-auto max-w-2xl text-center">
      <h2 class="font-heading text-h2 font-semibold tracking-tight text-primary-fg sm:text-h1">
        {title}
      </h2>
      <p class="mx-auto mt-5 max-w-lg text-base leading-relaxed text-primary-fg/75 sm:text-lead">
        {description}
      </p>

      <div class="mt-10 flex flex-col items-center gap-5 sm:flex-row sm:justify-center sm:gap-8">
        <a
          href={buttonHref}
          class="inline-flex min-h-[48px] items-center justify-center bg-accent px-8 py-3 text-sm font-semibold tracking-wide text-accent-fg transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
        >
          {buttonText}
        </a>
        <a
          href={`tel:${client.phoneForTel}`}
          class="text-sm font-medium text-primary-fg/80 underline-offset-4 transition-colors hover:text-primary-fg hover:underline"
        >
          {client.phoneFormatted}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes cta-rise {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cta-rise {
    animation: cta-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-rise {
      animation: none;
    }
  }
</style>
