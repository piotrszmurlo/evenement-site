---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title = 'Zadzwoń do nas',
  description = 'Porozmawiajmy o Twoim wymarzonym domu — chętnie odpowiemy na pytania i umówimy spotkanie.',
  buttonText = 'Zadzwoń',
  buttonHref = '/kontakt',
} = Astro.props;
---

<section class="relative overflow-hidden bg-dark py-20 sm:py-24 lg:py-28">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_80%_120%,color-mix(in_srgb,var(--color-primary-light)_35%,transparent),transparent_70%)]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-site px-4 sm:px-6">
    <div class="cta-rise mx-auto max-w-2xl text-center">
      <h2 class="font-heading text-h2 font-semibold tracking-tight text-primary-fg sm:text-h1">
        {title}
      </h2>
      <p class="mx-auto mt-5 max-w-lg text-base leading-relaxed text-primary-fg/75 sm:text-lead">
        {description}
      </p>

      <div class="mt-10">
        <a
          href={buttonHref}
          class="btn-accent"
        >
          {buttonText}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes cta-rise {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cta-rise {
    animation: cta-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-rise {
      animation: none;
    }
  }
</style>
