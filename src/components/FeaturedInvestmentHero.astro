---
import { Image } from 'astro:assets';
import ImagePlaceholder from './ImagePlaceholder.astro';
import { brand } from '../config/brand';
import type { Investment } from '../lib/content';

interface Props {
  investment: Investment;
  /** Show brand logo above the investment name (homepage). */
  showBrand?: boolean;
  ctaLabel?: string;
  headingLevel?: 'h1' | 'h2';
}

const {
  investment,
  showBrand = false,
  ctaLabel = 'Zobacz szczegóły inwestycji',
  headingLevel = 'h1',
} = Astro.props;

const HeadingTag = headingLevel;
---

<a
  href={`/inwestycje/${investment.slug}/`}
  class="group relative block overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-background"
>
  <div class="relative min-h-[min(90vh,920px)] w-full">
    {investment.coverImage ? (
      <Image
        src={investment.coverImage}
        alt={investment.name}
        width={1920}
        height={1080}
        class="absolute inset-0 size-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
        loading="eager"
        fetchpriority="high"
      />
    ) : (
      <ImagePlaceholder
        label="Placeholder inwestycji do uzupełnienia"
        class="absolute inset-0 size-full min-h-[min(90vh,920px)]"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-dark/92 via-dark/45 to-dark/15"></div>
    <div class="absolute inset-x-0 bottom-0 mx-auto max-w-site px-4 py-6 sm:px-6 sm:py-10 lg:py-14">
      {showBrand && (
        <img
          src="/logo.png"
          alt={brand.name}
          width="220"
          height="65"
          class="mb-5 h-10 w-auto brightness-0 invert sm:mb-6 sm:h-12"
          decoding="async"
        />
      )}
      <span class="mb-4 inline-block rounded-full bg-accent px-3 py-1 text-xs font-bold uppercase tracking-widest text-accent-fg">
        W sprzedaży
      </span>
      <HeadingTag class="font-heading text-display font-bold uppercase text-primary-fg">
        {investment.name}
      </HeadingTag>
      <p class="mt-3 flex max-w-xl items-center gap-1.5 text-sm text-primary-fg/85 sm:text-base">
        <svg class="size-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        {investment.locationAddress}
      </p>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-primary-fg/75 sm:text-base">
        {investment.summary}
      </p>
      <span class="mt-8 inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity group-hover:opacity-90">
        {ctaLabel}
      </span>
    </div>
  </div>
</a>
