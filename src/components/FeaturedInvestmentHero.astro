---
import { Image } from 'astro:assets';
import ImagePlaceholder from './ImagePlaceholder.astro';
import type { Investment } from '../lib/content';

interface Props {
  investment: Investment;
  ctaLabel?: string;
  headingLevel?: 'h1' | 'h2';
  statusLabel?: string;
  /** Extra bottom margin when used above other listing sections. */
  class?: string;
}

const {
  investment,
  ctaLabel = 'Zobacz dostępne oferty',
  headingLevel = 'h1',
  statusLabel = investment.salesStatus === 'active' ? 'Aktualna inwestycja' : 'Zrealizowana inwestycja',
  class: className,
} = Astro.props;

const HeadingTag = headingLevel;
---

<a
  href={`/inwestycje/${investment.slug}/`}
  class:list={[
    'group relative block min-h-[min(92svh,880px)] overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-background',
    className,
  ]}
>
  {investment.coverImage ? (
    <Image
      src={investment.coverImage}
      alt={investment.name}
      width={1920}
      height={1080}
      class="absolute inset-0 size-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
      loading="eager"
      fetchpriority="high"
    />
  ) : (
    <ImagePlaceholder
      label="Placeholder inwestycji do uzupełnienia"
      class="absolute inset-0 size-full min-h-[min(92svh,880px)]"
    />
  )}

  <div
    class="absolute inset-0 bg-gradient-to-t from-dark via-dark/45 to-dark/10"
    aria-hidden="true"
  ></div>

  <div class="absolute inset-x-0 bottom-0">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16 lg:py-20">
      <p class="text-topper font-semibold tracking-[0.18em] text-accent">
        {statusLabel}
      </p>
      <HeadingTag class="mt-3 max-w-3xl font-heading text-h1 font-semibold tracking-tight text-primary-fg sm:text-display">
        {investment.name}
      </HeadingTag>
      <p class="mt-4 max-w-xl text-sm text-primary-fg/80 sm:text-base">
        {investment.locationAddress}
      </p>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-primary-fg/70 sm:text-base">
        {investment.summary}
      </p>
      <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-primary-fg transition-colors group-hover:text-accent sm:text-base">
        {ctaLabel}
        <svg
          class="size-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
