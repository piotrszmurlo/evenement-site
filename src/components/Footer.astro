---
import { brand } from '../config/brand';
import { client } from '../data/client';

const year = new Date().getFullYear();

const navCols = [
  {
    title: 'Nawigacja',
    links: [
      { label: 'Strona główna', href: '/' },
      { label: 'O nas',         href: '/o-nas' },
      { label: 'Inwestycje',    href: '/inwestycje' },
      { label: 'Kontakt',       href: '/kontakt' },
    ],
  },
];
---

<footer class="bg-dark text-surface/80" transition:persist>
  <div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="font-heading text-lg font-bold uppercase tracking-wide text-white">
          {brand.name}
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">
          {brand.tagline}
        </p>

      </div>

      <!-- Nav columns -->
      {navCols.map((col) => (
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-white">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm transition-colors hover:text-white">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Contact info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Kontakt</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href={`tel:${client.phoneForTel}`} class="transition-colors hover:text-white">
              {client.phoneFormatted}
            </a>
          </li>
          <li>
            <a href={`mailto:${client.email}`} class="transition-colors hover:text-white">
              {client.email}
            </a>
          </li>
          <li>
            <a href={client.address.mapLink} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
              {client.address.lineOne}<br />
              {client.address.city}, {client.address.state} {client.address.zip}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Disclaimer & copyright -->
    <div class="mt-10 border-t border-surface/10 pt-6 text-center">
      <p class="mx-auto mb-6 max-w-4xl text-xs leading-relaxed text-surface/60">
        Przedstawione na stronie internetowej materiały graficzne tj. wizualizacje, animacje oraz modele budynku/budynków mają charakter poglądowy. Na etapie realizacji inwestycji nieznacznie mogą ulec zmianie wygląd budynku/budynków oraz zagospodarowanie terenu. Zmianie nie ulegną istotne cechy świadczenia oraz funkcjonalności budynku/budynków. Przedstawione materiały graficzne nie mogą być traktowane jako ostateczne projekty realizacyjne. Wiążące informacje dotyczące inwestycji, w tym standardu wykonania, zagospodarowania terenu oraz parametrów lokali znajdują się w dokumentacji projektowej, oraz w prospekcie informacyjnym. Zamieszczone na stronie internetowej informacje nie stanowią oferty handlowej, w szczególności oferty w rozumieniu art. 66 §1 kc.
      </p>
      <p class="text-sm">
        &copy; {year} {brand.name}. Wszelkie prawa zastrzeżone.
      </p>
    </div>
  </div>
</footer>
