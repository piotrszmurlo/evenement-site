---
import { brand } from '../config/brand';
import { client } from '../data/client';

const year = new Date().getFullYear();

const navCols = [
  {
    title: 'Nawigacja',
    links: [
      { label: 'Strona główna', href: '/' },
      { label: 'O nas',         href: '/o-nas', hidden: true },
      { label: 'Inwestycje',    href: '/inwestycje' },
      { label: 'Kontakt',       href: '/kontakt' },
    ],
  },
];
---

<footer class="bg-dark text-surface/80" transition:persist>
  <div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center" aria-label={brand.name}>
          <img
            src="/logo.png"
            alt={brand.name}
            width="148"
            height="44"
            class="h-10 w-auto brightness-0 invert opacity-95"
            decoding="async"
          />
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">
          {brand.tagline}
        </p>

      </div>

      <!-- Nav columns -->
      {navCols.map((col) => (
        <div>
          <h3 class="topper text-primary-fg">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.filter((link) => !link.hidden).map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm transition-colors hover:text-primary-fg">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Contact info -->
      <div>
        <h3 class="topper text-primary-fg">Biuro sprzedaży</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <span class="block text-primary-fg/90">{client.salesPartner.name}</span>
            <a href={client.salesOffice.mapLink} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-primary-fg">
              {client.salesOffice.lineOne}<br />
              {client.salesOffice.lineTwo}
            </a>
          </li>
          <li>
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
              <a href={`tel:${client.salesPartner.phone}`} class="transition-colors hover:text-primary-fg">
                {client.salesPartner.phoneFormatted}
              </a>
              <span class="text-xs text-surface/50">Biuro sprzedaży</span>
            </div>
          </li>
          <li>
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
              <a href={`tel:${client.phoneForTel}`} class="transition-colors hover:text-primary-fg">
                {client.phoneFormatted}
              </a>
              <span class="text-xs text-surface/50">Deweloper</span>
            </div>
          </li>
          <li>
            <a href={`mailto:${client.salesPartner.email}`} class="transition-colors hover:text-primary-fg">
              {client.salesPartner.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Disclaimer & copyright -->
    <div class="mt-10 border-t border-surface/10 pt-6 text-center">
      <p class="mx-auto mb-6 max-w-4xl text-xs leading-relaxed text-surface/60">
        Przedstawione na stronie internetowej materiały graficzne tj. wizualizacje, animacje oraz modele budynku/budynków mają charakter poglądowy. Na etapie realizacji inwestycji nieznacznie mogą ulec zmianie wygląd budynku/budynków oraz zagospodarowanie terenu. Zmianie nie ulegną istotne cechy świadczenia oraz funkcjonalności budynku/budynków. Przedstawione materiały graficzne nie mogą być traktowane jako ostateczne projekty realizacyjne. Wiążące informacje dotyczące inwestycji, w tym standardu wykonania, zagospodarowania terenu oraz parametrów lokali znajdują się w dokumentacji projektowej, oraz w prospekcie informacyjnym. Zamieszczone na stronie internetowej informacje nie stanowią oferty handlowej, w szczególności oferty w rozumieniu art. 66 §1 kc.
      </p>
      <p class="text-sm">
        &copy; {year} {brand.name}. Wszelkie prawa zastrzeżone.
      </p>
    </div>
  </div>
</footer>
