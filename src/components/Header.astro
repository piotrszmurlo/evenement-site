---
import { brand } from "../config/brand";
import { client } from "../data/client";

interface Props {
  /** Transparent header over a dark full-bleed hero (homepage). */
  overlay?: boolean;
}

const { overlay = false } = Astro.props;

const nav = [
  { label: "Strona główna", href: "/" },
  { label: "Inwestycje", href: "/inwestycje" },
  { label: "Kontakt", href: "/kontakt" },
  { label: "O nas", href: "/o-nas", hidden: true },
];

const currentPath = Astro.url.pathname;
---

<header
  class:list={[
    "z-50 w-full transition-[background-color,border-color,backdrop-filter] duration-300",
    overlay ? "fixed top-0 border-b border-transparent" : "sticky top-0 border-b border-border bg-background/95 backdrop-blur-sm",
  ]}
  data-header-overlay={overlay ? "true" : undefined}
>
  <div
    class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6"
  >
    <!-- Logo -->
    <a
      href="/"
      class="inline-flex items-center transition-opacity hover:opacity-80"
      aria-label={brand.name}
    >
      <img
        src="/logo.png"
        alt={brand.name}
        width="136"
        height="40"
        class:list={[
          "h-9 w-auto transition-[filter] duration-300",
          overlay && "brightness-0 invert",
        ]}
        data-overlay-logo={overlay ? "" : undefined}
        decoding="async"
      />
    </a>

    <!-- Desktop nav -->
    <nav
      class="hidden items-center gap-1 lg:flex"
      aria-label="Primary navigation"
      data-overlay-nav={overlay ? "" : undefined}
    >
      {
        nav.filter((item) => !item.hidden).map(({ label, href }) => {
          const isActive =
            currentPath === href ||
            (href !== "/" && currentPath.startsWith(href));
          return (
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "rounded-md px-3 py-2 text-sm font-medium transition-colors",
                overlay
                  ? isActive
                    ? "bg-primary-fg/15 text-primary-fg"
                    : "text-primary-fg/75 hover:text-primary-fg"
                  : isActive
                    ? "bg-primary/10 text-primary"
                    : "text-text-muted hover:text-text",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <!-- Desktop CTA + phone -->
    <div
      class="hidden items-center gap-4 lg:flex"
      data-overlay-actions={overlay ? "" : undefined}
    >
      {
        client.license && (
          <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-muted">
            {client.license}
          </span>
        )
      }
      <a
        href={`tel:${client.phoneForTel}`}
        class:list={[
          "text-sm font-semibold transition-colors",
          overlay
            ? "text-primary-fg/85 hover:text-primary-fg"
            : "text-text hover:text-primary",
        ]}
      >
        {client.phoneFormatted}
      </a>
      <a
        href="/kontakt"
        class="inline-flex min-h-[44px] items-center bg-accent px-5 py-2.5 text-sm font-semibold tracking-wide text-accent-fg transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Kontakt
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class:list={[
        "inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md lg:hidden",
        overlay
          ? "text-primary-fg hover:bg-primary-fg/10"
          : "text-text-muted hover:bg-surface",
      ]}
      data-overlay-toggle={overlay ? "" : undefined}
    >
      <span class="sr-only">Otwórz menu</span>
      <svg
        id="menu-icon-open"
        class="size-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="menu-icon-close"
        class="hidden size-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-background px-4 pb-6 pt-2 lg:hidden"
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
      {
        nav.filter((item) => !item.hidden).map(({ label, href }) => {
          const isActive =
            currentPath === href ||
            (href !== "/" && currentPath.startsWith(href));
          return (
            <a
              href={href}
              class:list={[
                "rounded-md px-3 py-3 text-base font-medium transition-colors",
                isActive
                  ? "bg-primary/10 text-primary"
                  : "text-text-muted hover:text-text hover:bg-surface",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <div class="mt-4 flex flex-col gap-3 border-t border-border pt-4">
      <a
        href={`tel:${client.phoneForTel}`}
        class="flex items-center gap-2 px-3 py-2 text-base font-semibold text-text"
      >
        <svg
          class="size-5 text-primary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        {client.phoneFormatted}
      </a>
      <a
        href="/kontakt"
        class="flex min-h-[44px] items-center justify-center bg-accent px-5 py-3 text-base font-semibold tracking-wide text-accent-fg transition-opacity hover:opacity-90"
      >
        Kontakt
      </a>
      {
        client.license && (
          <p class="px-3 pt-1 text-xs text-text-muted">{client.license}</p>
        )
      }
    </div>
  </div>
</header>

<script>
  const initHeaderMenu = () => {
    const headerEl = document.querySelector("header");
    const btnEl = document.getElementById("menu-toggle");
    const menuEl = document.getElementById("mobile-menu");
    const iconOpenEl = document.getElementById("menu-icon-open");
    const iconCloseEl = document.getElementById("menu-icon-close");

    if (!headerEl || !btnEl || !menuEl || !iconOpenEl || !iconCloseEl) return;

    const header = /** @type {HTMLElement} */ (headerEl);
    const btn = /** @type {HTMLButtonElement} */ (btnEl);
    const menu = /** @type {HTMLElement} */ (menuEl);
    const iconOpen = /** @type {HTMLElement} */ (iconOpenEl);
    const iconClose = /** @type {HTMLElement} */ (iconCloseEl);
    const isOverlay = header.dataset.headerOverlay === "true";
    const logo = header.querySelector("[data-overlay-logo]");

    const activeClasses = ["bg-primary/10", "text-primary"];
    const inactiveDesktop = ["text-text-muted", "hover:text-text"];
    const inactiveMobile = [
      "text-text-muted",
      "hover:text-text",
      "hover:bg-surface",
    ];

    const isDesktop = () => window.matchMedia("(min-width: 1024px)").matches;

    const setOverlaySolid = (solid) => {
      if (!isOverlay) return;

      header.classList.toggle("border-border", solid);
      header.classList.toggle("border-transparent", !solid);
      header.classList.toggle("bg-background/95", solid);
      header.classList.toggle("backdrop-blur-sm", solid);

      if (logo) {
        logo.classList.toggle("brightness-0", !solid);
        logo.classList.toggle("invert", !solid);
      }

      const navLinks = header.querySelectorAll(
        'nav[aria-label="Primary navigation"] a',
      );
      navLinks.forEach((link) => {
        const isActive = link.getAttribute("aria-current") === "page";
        link.classList.remove(
          "bg-primary-fg/15",
          "text-primary-fg",
          "text-primary-fg/75",
          "hover:text-primary-fg",
          "bg-primary/10",
          "text-primary",
          "text-text-muted",
          "hover:text-text",
        );
        if (solid) {
          if (isActive) {
            link.classList.add("bg-primary/10", "text-primary");
          } else {
            link.classList.add("text-text-muted", "hover:text-text");
          }
        } else if (isActive) {
          link.classList.add("bg-primary-fg/15", "text-primary-fg");
        } else {
          link.classList.add("text-primary-fg/75", "hover:text-primary-fg");
        }
      });

      const phone = header.querySelector("[data-overlay-actions] a[href^='tel:']");
      if (phone) {
        phone.classList.remove(
          "text-primary-fg/85",
          "hover:text-primary-fg",
          "text-text",
          "hover:text-primary",
        );
        if (solid) {
          phone.classList.add("text-text", "hover:text-primary");
        } else {
          phone.classList.add("text-primary-fg/85", "hover:text-primary-fg");
        }
      }

      btn.classList.remove(
        "text-primary-fg",
        "hover:bg-primary-fg/10",
        "text-text-muted",
        "hover:bg-surface",
      );
      if (solid) {
        btn.classList.add("text-text-muted", "hover:bg-surface");
      } else {
        btn.classList.add("text-primary-fg", "hover:bg-primary-fg/10");
      }
    };

    const syncOverlayFromScroll = () => {
      if (!isOverlay) return;
      const menuOpen = btn.getAttribute("aria-expanded") === "true";
      setOverlaySolid(menuOpen || window.scrollY > 24);
    };

    const setMenuOpen = (nextOpen) => {
      if (isDesktop()) nextOpen = false;
      btn.setAttribute("aria-expanded", String(nextOpen));
      menu.classList.toggle("hidden", !nextOpen);
      iconOpen.classList.toggle("hidden", nextOpen);
      iconClose.classList.toggle("hidden", !nextOpen);
      if (isOverlay) {
        setOverlaySolid(nextOpen || window.scrollY > 24);
      }
    };

    const syncActiveLinks = () => {
      const path = window.location.pathname;
      const desktopLinks = header.querySelectorAll(
        'nav[aria-label="Primary navigation"] a',
      );
      const mobileLinks = header.querySelectorAll("#mobile-menu nav a");

      desktopLinks.forEach((link) => {
        const href = link.getAttribute("href") || "";
        const isActive =
          href === path || (href !== "/" && path.startsWith(href));
        if (isActive) link.setAttribute("aria-current", "page");
        else link.removeAttribute("aria-current");
      });

      mobileLinks.forEach((link) => {
        const href = link.getAttribute("href") || "";
        const isActive =
          href === path || (href !== "/" && path.startsWith(href));
        link.classList.toggle(activeClasses[0], isActive);
        link.classList.toggle(activeClasses[1], isActive);
        link.classList.toggle(inactiveMobile[0], !isActive);
        link.classList.toggle(inactiveMobile[1], !isActive);
        link.classList.toggle(inactiveMobile[2], !isActive);
        if (isActive) link.setAttribute("aria-current", "page");
        else link.removeAttribute("aria-current");
      });

      if (isOverlay) syncOverlayFromScroll();
      else {
        desktopLinks.forEach((link) => {
          const isActive = link.getAttribute("aria-current") === "page";
          link.classList.toggle(activeClasses[0], isActive);
          link.classList.toggle(activeClasses[1], isActive);
          link.classList.toggle(inactiveDesktop[0], !isActive);
          link.classList.toggle(inactiveDesktop[1], !isActive);
        });
      }
    };

    if (header.dataset.menuInit !== "true") {
      header.dataset.menuInit = "true";

      btn.addEventListener("click", () => {
        if (isDesktop()) return;
        const isOpen = btn.getAttribute("aria-expanded") === "true";
        setMenuOpen(!isOpen);
      });

      menu.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest("a[href]")) setMenuOpen(false);
      });

      document.addEventListener("astro:before-preparation", () =>
        setMenuOpen(false),
      );
      document.addEventListener("astro:after-swap", () => {
        setMenuOpen(false);
        syncActiveLinks();
      });

      window.addEventListener("resize", () => setMenuOpen(false));
      window.addEventListener("scroll", syncOverlayFromScroll, { passive: true });
    }

    setMenuOpen(false);
    syncActiveLinks();
    syncOverlayFromScroll();
  };

  initHeaderMenu();
  document.addEventListener("astro:page-load", initHeaderMenu);
</script>
