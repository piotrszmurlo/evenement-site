---
import { brand } from '../config/brand';
import { heroImage as localHeroImage } from '../config/images';

const PLACEHOLDER = 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1600&q=80';

interface Props {
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: string;
  imageGallery?: string[];
  imageAlt?: string;
}

const {
  heading = brand.tagline,
  description = brand.description,
  ctaLabel = 'Zobacz inwestycje',
  ctaHref = '/inwestycje',
  imageSrc,
  imageGallery = [],
  imageAlt = 'Osiedle mieszkaniowe Evenement',
} = Astro.props;

const fallbackImage =
  typeof localHeroImage === 'string'
    ? localHeroImage
    : localHeroImage?.src ?? PLACEHOLDER;

const galleryImages =
  imageGallery.length > 0
    ? imageGallery
    : [imageSrc ?? fallbackImage];
---

<section
  class="relative isolate min-h-[100svh] overflow-hidden bg-dark text-primary-fg"
  data-hero-gallery-root
  aria-label="Wprowadzenie"
>
  <div class="absolute inset-0" data-hero-gallery>
    <div class="embla h-full overflow-hidden" data-hero-gallery-viewport>
      <div class="embla__container flex h-full">
        {galleryImages.map((src, index) => (
          <div class="embla__slide relative min-w-0 flex-[0_0_100%] overflow-hidden">
            <img
              src={src}
              alt={index === 0 ? imageAlt : ''}
              aria-hidden={index === 0 ? undefined : 'true'}
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : undefined}
              decoding="async"
              class="hero-slide-image absolute inset-0 size-full object-cover"
            />
          </div>
        ))}
      </div>
    </div>
  </div>

  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-r from-dark/88 via-dark/55 to-dark/25"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-dark/40"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto flex min-h-[100svh] max-w-site flex-col justify-end px-4 pb-14 pt-28 sm:px-6 sm:pb-16 lg:pb-20">
    <div class="hero-copy max-w-xl space-y-6 sm:space-y-7">
      <img
        src="/logo.png"
        alt={brand.name}
        width="320"
        height="95"
        class="h-12 w-auto brightness-0 invert sm:h-14 md:h-16"
        decoding="async"
        transition:name="hero-brand"
      />

      <h1
        class="font-heading text-[clamp(2.625rem,1rem+8vw,5rem)] font-semibold leading-[1.05] tracking-tight text-primary-fg"
        transition:name="hero-heading"
      >
        {heading}
      </h1>

      <p class="max-w-md text-lead leading-relaxed text-primary-fg/80">
        {description}
      </p>

      <div class="pt-1">
        <a
          href={ctaHref}
          class="inline-flex min-h-[48px] items-center justify-center bg-accent px-7 py-3 text-sm font-semibold tracking-wide text-accent-fg transition-[transform,opacity] duration-300 hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent active:scale-[0.98]"
        >
          {ctaLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-ken {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.06);
    }
  }

  .hero-copy {
    animation: hero-rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-slide-image {
    animation: hero-ken 18s ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-copy,
    .hero-slide-image {
      animation: none;
    }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';

  const AUTOPLAY_DELAY_MS = 5500;
  const HERO_GALLERY_KEY = '__heroGalleryCleanup';

  const destroyHeroGallery = () => {
    const root = document.querySelector('[data-hero-gallery]');
    const cleanup = root?.[HERO_GALLERY_KEY];
    if (typeof cleanup === 'function') cleanup();
  };

  const initHeroGallery = () => {
    const root = document.querySelector('[data-hero-gallery]');
    const viewport = root?.querySelector('[data-hero-gallery-viewport]');

    if (!root || !viewport) return;
    destroyHeroGallery();

    const slideCount = root.querySelectorAll('.embla__slide').length;
    if (slideCount <= 1) return;

    const embla = EmblaCarousel(viewport, {
      loop: true,
      align: 'start',
      skipSnaps: false,
      containScroll: false,
      watchDrag: true,
      duration: 40,
    });

    let autoplayId = window.setInterval(() => {
      embla.scrollNext();
    }, AUTOPLAY_DELAY_MS);

    const restartAutoplay = () => {
      window.clearInterval(autoplayId);
      autoplayId = window.setInterval(() => {
        embla.scrollNext();
      }, AUTOPLAY_DELAY_MS);
    };

    embla.on('pointerDown', restartAutoplay);
    embla.on('settle', restartAutoplay);
    root[HERO_GALLERY_KEY] = () => {
      window.clearInterval(autoplayId);
      embla.destroy();
      delete root[HERO_GALLERY_KEY];
    };
  };

  initHeroGallery();
  document.addEventListener('astro:page-load', initHeroGallery);
  document.addEventListener('astro:before-swap', destroyHeroGallery);
</script>
