---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;
---

<div class:list={[
  'flex items-center justify-center bg-surface text-center text-sm font-medium text-text-muted',
  className,
]}>
  <div class="px-6 py-10">
    <svg
      class="mx-auto size-10 text-border"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      aria-hidden="true"
    >
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="M8 13l2.5-2.5a1 1 0 011.414 0L16 14.586" />
      <path d="M14 12l1.5-1.5a1 1 0 011.414 0L19 12.586" />
      <circle cx="9" cy="9" r="1.25" />
    </svg>
  </div>
</div>
