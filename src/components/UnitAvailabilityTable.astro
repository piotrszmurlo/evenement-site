---
import type { Unit } from '../lib/content';
import { formatAreaM2 } from '../lib/content';

interface Props {
  units: Unit[];
}

const { units } = Astro.props;

const formatPriceHistoryDate = (value: string) => {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat('pl-PL', {
    timeZone: 'UTC',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
};

const statusLabel = (status: Unit['status']) =>
  status === 'available' ? 'Dostępny' : status === 'reserved' ? 'Rezerwacja' : 'Sprzedany';

const roomsLabel = (rooms: number) => {
  if (rooms === 1) return '1 pokój';
  if (rooms >= 2 && rooms <= 4) return `${rooms} pokoje`;
  return `${rooms} pokoi`;
};
---

<div class="border-t border-border pt-12">
  <div class="mb-8 max-w-2xl">
    <h3 class="font-heading text-h3 font-semibold tracking-tight text-text">Dostępne nieruchomości</h3>
    <p class="mt-2 text-sm leading-relaxed text-text-muted">
      Aktualna oferta — metraż, cena i dostępność.
    </p>
  </div>

  <div class="divide-y divide-border border-y border-border">
    {units.map((unit) => {
      const currentPrice = unit.currentPrice;
      const priceLabel = currentPrice
        ? `${currentPrice.totalPrice.toLocaleString('pl-PL')} zł`
        : 'Cena na zapytanie';
      const ppmLabel = currentPrice
        ? `${currentPrice.pricePerM2.toLocaleString('pl-PL')} zł/m²`
        : '';
      const priceHistory = unit.priceHistory.map((entry) => ({
        date: formatPriceHistoryDate(entry.validFrom),
        ppm: `${entry.pricePerM2.toLocaleString('pl-PL')} zł/m²`,
        total: `${entry.totalPrice.toLocaleString('pl-PL')} zł`,
      }));

      return (
        <article class="py-6 sm:py-7">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start sm:gap-8">
            <div class="min-w-0">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h4 class="font-heading text-lg font-semibold tracking-tight text-text sm:text-xl">
                  {unit.unitNumber}
                </h4>
                <span
                  class:list={[
                    'text-sm font-semibold tracking-wide',
                    unit.status === 'available'
                      ? 'text-accent'
                      : unit.status === 'reserved'
                        ? 'text-secondary'
                        : 'text-text-muted',
                  ]}
                >
                  {statusLabel(unit.status)}
                </span>
              </div>
              {unit.description && (
                <p class="mt-1.5 text-sm leading-relaxed text-text">{unit.description}</p>
              )}
              <p class="mt-2 text-sm leading-relaxed text-text-muted">
                {formatAreaM2(unit.usableAreaM2)} m² · działka {formatAreaM2(unit.plotAreaM2)} m² · {roomsLabel(unit.rooms)}
              </p>
            </div>

            <div class="sm:pt-0.5 sm:text-right">
              <p class="font-heading text-lg font-semibold tracking-tight text-text sm:text-xl">
                {priceLabel}
              </p>
              {ppmLabel && (
                <p class="mt-1 text-sm text-text-muted">{ppmLabel}</p>
              )}
            </div>
          </div>

          <div class="mt-4 flex flex-wrap items-start justify-between gap-x-5 gap-y-3">
            <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
              {unit.floorPlanUrl && (
                <a
                  href={unit.floorPlanUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-[44px] items-center gap-1.5 text-sm font-semibold text-text transition-colors hover:text-accent"
                >
                  Rzuty
                  <svg class="size-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M7 17L17 7M17 7H9M17 7v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              )}

              {unit.status !== 'sold' && (
                <a
                  href="/kontakt/"
                  class="inline-flex min-h-[44px] items-center gap-1.5 text-sm font-semibold text-text transition-colors hover:text-accent"
                >
                  Zapytaj o {unit.unitNumber}
                  <svg class="size-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              )}
            </div>

            <details class="group/history max-w-md sm:text-right">
              <summary class="inline-flex min-h-[44px] cursor-pointer list-none items-center gap-1.5 text-sm text-text-muted transition-colors hover:text-text [&::-webkit-details-marker]:hidden">
                Historia zmian ceny
                <svg
                  class="size-3.5 transition-transform group-open/history:rotate-180"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              {priceHistory.length > 0 ? (
                <ul class="mt-2 space-y-2 sm:ml-auto">
                  {priceHistory.map((entry) => (
                    <li class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 text-sm sm:justify-end">
                      <span class="text-text-muted">{entry.date}</span>
                      <span class="font-medium text-text">
                        {entry.total}
                        <span class="ml-2 font-normal text-text-muted">{entry.ppm}</span>
                      </span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="mt-2 text-sm text-text-muted">Brak wcześniejszych zmian ceny.</p>
              )}
            </details>
          </div>
        </article>
      );
    })}
  </div>
</div>
