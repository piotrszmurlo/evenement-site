---
/**
 * PROTOTYPE — floating variant switcher. Delete with the prototype.
 * Client-toggles [data-prototype-variant] panels; syncs ?variant= via replaceState.
 */
interface Props {
  variants: { key: string; name: string }[];
  param?: string;
}

const { variants, param = 'variant' } = Astro.props;
const keys = variants.map((v) => v.key);
const labels = Object.fromEntries(variants.map((v) => [v.key, v.name]));
---

{
  import.meta.env.DEV && (
    <div
      class="fixed bottom-5 left-1/2 z-[9999] flex -translate-x-1/2 items-center gap-1 rounded-full border border-black/20 bg-black px-1.5 py-1.5 text-white shadow-2xl"
      data-prototype-switcher
      data-param={param}
      data-keys={JSON.stringify(keys)}
      data-labels={JSON.stringify(labels)}
      role="group"
      aria-label="Prototype variant switcher"
    >
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full text-white/80 transition-colors hover:bg-white/15 hover:text-white"
        data-prototype-prev
        aria-label="Previous variant"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <p class="min-w-[11rem] px-2 text-center text-xs font-semibold tracking-wide" data-prototype-label>
        —
      </p>
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full text-white/80 transition-colors hover:bg-white/15 hover:text-white"
        data-prototype-next
        aria-label="Next variant"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  )
}

{
  import.meta.env.DEV && (
    <script>
      const switcher = document.querySelector('[data-prototype-switcher]');
      if (switcher) {
        const param = switcher.getAttribute('data-param') || 'variant';
        const keys = JSON.parse(switcher.getAttribute('data-keys') || '[]');
        const labels = JSON.parse(switcher.getAttribute('data-labels') || '{}');
        const labelEl = switcher.querySelector('[data-prototype-label]');
        const prevBtn = switcher.querySelector('[data-prototype-prev]');
        const nextBtn = switcher.querySelector('[data-prototype-next]');

        const readVariant = () => {
          const fromUrl = new URL(window.location.href).searchParams.get(param);
          return keys.includes(fromUrl) ? fromUrl : keys[0];
        };

        const applyVariant = (key) => {
          document.querySelectorAll('[data-prototype-variant]').forEach((panel) => {
            const match = panel.getAttribute('data-prototype-variant') === key;
            panel.toggleAttribute('hidden', !match);
          });

          if (labelEl) {
            labelEl.textContent = `${key} — ${labels[key] || key}`;
          }

          const url = new URL(window.location.href);
          url.searchParams.set(param, key);
          history.replaceState(null, '', url);
        };

        const cycle = (delta) => {
          const current = readVariant();
          const index = keys.indexOf(current);
          const next = keys[(index + delta + keys.length) % keys.length];
          applyVariant(next);
        };

        prevBtn?.addEventListener('click', () => cycle(-1));
        nextBtn?.addEventListener('click', () => cycle(1));

        document.addEventListener('keydown', (event) => {
          const target = event.target;
          if (
            target instanceof HTMLElement &&
            (target.closest('input, textarea, select, [contenteditable="true"]') ||
              target.isContentEditable)
          ) {
            return;
          }

          if (event.key === 'ArrowLeft') {
            event.preventDefault();
            cycle(-1);
          }
          if (event.key === 'ArrowRight') {
            event.preventDefault();
            cycle(1);
          }
        });

        applyVariant(readVariant());
      }
    </script>
  )
}
