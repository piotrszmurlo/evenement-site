---
/**
 * Base layout — wraps every page.
 *
 * Astro 6 features used:
 *  • <Font />         — built-in font optimizer from astro.config.mjs fonts array
 *  • <ClientRouter /> — client-side navigation with CSS transition animations
 */
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { brand } from '../config/brand';
import { client } from '../data/client';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  /** When set with imageHeight, emitted as og:image dimensions (skip for unknown CMS covers). */
  imageWidth?: number;
  imageHeight?: number;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = brand.seoTitle,
  description = brand.description,
  image = brand.ogImage.path,
  imageAlt = brand.ogImage.alt,
  imageWidth = image === brand.ogImage.path ? brand.ogImage.width : undefined,
  imageHeight = image === brand.ogImage.path ? brand.ogImage.height : undefined,
  schema,
} = Astro.props;

const siteURL = Astro.site ?? brand.url;
const pageTitle = title.includes(brand.name) ? title : `${title} — ${brand.name}`;
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = new URL(image, siteURL);
const schemaDocument = Array.isArray(schema)
  ? {
      '@context': 'https://schema.org',
      '@graph': schema.map(({ '@context': _context, ...node }) => node),
    }
  : schema;
---

<html lang={brand.locale.split('_')[0]} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={brand.name} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />
    {imageWidth != null && <meta property="og:image:width" content={String(imageWidth)} />}
    {imageHeight != null && <meta property="og:image:height" content={String(imageHeight)} />}
    <meta property="og:image:alt"   content={imageAlt} />
    <meta property="og:locale"      content={brand.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />
    <meta name="twitter:image:alt"   content={imageAlt} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body"    preload />

    <!-- JSON-LD Structured Data -->
    {schemaDocument && (
      <script type="application/ld+json" set:html={JSON.stringify(schemaDocument)} />
    )}

    <!-- FOUC prevention for dark mode -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark-mode');
        }
      })();
    </script>

    <slot name="head" />
    <ClientRouter />
  </head>

  <body class="bg-background text-text font-body antialiased">
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:z-[99999] focus:bg-primary focus:text-primary-fg focus:px-4 focus:py-2 focus:rounded-md"
      href="#main"
    >
      Przejdź do treści
    </a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
