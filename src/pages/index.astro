---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { Image } from 'astro:assets';
import { getHomepageContent, getInvestments } from '../lib/content';

const homepageContent = await getHomepageContent();
const investments = await getInvestments();
const featuredInvestment =
  investments.find((investment) => investment.salesStatus === 'active') ?? investments[0];
const heroGallery =
  homepageContent.homepageGallery.length > 0
    ? homepageContent.homepageGallery
    : featuredInvestment?.gallery ?? [];
---

<BaseLayout
  title={brand.name}
  description={brand.description}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: client.name,
    telephone: client.phoneForTel,
    email: client.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: client.address.lineOne,
      addressLocality: client.address.city,
      addressRegion: client.address.state,
      postalCode: client.address.zip,
      addressCountry: client.address.country,
    },
    url: client.domain,
  }}
>
  <Header slot="header" overlay />

  <Hero imageGallery={heroGallery} imageAlt={featuredInvestment?.name ?? 'Osiedle mieszkaniowe Evenement'} />

  {featuredInvestment && (
    <section class="bg-background" aria-labelledby="featured-investment-heading">
      <a
        href={`/inwestycje/${featuredInvestment.slug}/`}
        class="group relative block min-h-[min(92svh,880px)] overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      >
        {featuredInvestment.coverImage ? (
          <Image
            src={featuredInvestment.coverImage}
            alt={featuredInvestment.name}
            width={1920}
            height={1080}
            class="absolute inset-0 size-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
            loading="lazy"
          />
        ) : (
          <ImagePlaceholder
            label="Placeholder inwestycji do uzupełnienia"
            class="absolute inset-0 size-full min-h-[min(92svh,880px)]"
          />
        )}

        <div
          class="absolute inset-0 bg-gradient-to-t from-dark via-dark/45 to-dark/10"
          aria-hidden="true"
        ></div>

        <div class="absolute inset-x-0 bottom-0">
          <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16 lg:py-20">
            <p class="topper topper-on-media text-accent">
              Aktualna inwestycja
            </p>
            <h2
              id="featured-investment-heading"
              class="mt-3 max-w-3xl font-heading text-h1 font-semibold tracking-tight text-primary-fg sm:text-display"
            >
              {featuredInvestment.name}
            </h2>
            <p class="mt-4 max-w-xl text-sm text-primary-fg/80 sm:text-base">
              {featuredInvestment.locationAddress}
            </p>
            <p class="mt-4 max-w-2xl text-sm leading-relaxed text-primary-fg/70 sm:text-base">
              {featuredInvestment.summary}
            </p>
            <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-primary-fg transition-colors group-hover:text-accent sm:text-base">
              Zobacz dostępne oferty
              <svg
                class="size-4 transition-transform duration-300 group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
