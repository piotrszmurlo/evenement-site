---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { Image } from 'astro:assets';
import { getHomepageContent, getInvestments } from '../lib/content';

const homepageContent = await getHomepageContent();
const investments = await getInvestments();
const featuredInvestment =
  investments.find((investment) => investment.salesStatus === 'active') ?? investments[0];
const heroGallery =
  homepageContent.homepageGallery.length > 0
    ? homepageContent.homepageGallery
    : featuredInvestment?.gallery ?? [];
---

<BaseLayout
  title={brand.name}
  description={brand.description}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: client.name,
    telephone: client.phoneForTel,
    email: client.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: client.address.lineOne,
      addressLocality: client.address.city,
      addressRegion: client.address.state,
      postalCode: client.address.zip,
      addressCountry: client.address.country,
    },
    url: client.domain,
  }}
>
  <Header slot="header" />

  <Hero imageGallery={heroGallery} imageAlt={featuredInvestment?.name ?? 'Nowoczesne budynki mieszkalne'} />

  {featuredInvestment && (
    <section class="py-section bg-surface">
      <div class="mx-auto max-w-site px-4 sm:px-6">
        <div class="mx-auto mb-10 max-w-2xl text-center">
          <span class="text-topper font-bold uppercase tracking-widest text-accent">Aktualna Inwestycja</span>
          <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Poznaj Nasz Najnowszy Projekt</h2>
        </div>

        <div class="mx-auto grid max-w-5xl grid-cols-1 items-center gap-8 lg:grid-cols-2 lg:gap-14">
          <div class="overflow-hidden rounded-lg shadow-lg">
            {featuredInvestment.coverImage ? (
              <Image
                src={featuredInvestment.coverImage}
                alt={featuredInvestment.name}
                width={800}
                height={500}
                class="w-full object-cover transition-transform duration-300 hover:scale-105"
              />
            ) : (
              <ImagePlaceholder label="Placeholder inwestycji do uzupełnienia" class="min-h-[320px] w-full" />
            )}
          </div>
          <div class="space-y-6">
            <h3 class="font-heading text-h3 font-bold uppercase tracking-wide text-text">{featuredInvestment.name}</h3>
            <p class="flex items-center gap-1 text-sm text-text-muted">
              <svg class="size-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {featuredInvestment.locationAddress}
            </p>
            <p class="text-sm leading-relaxed text-text-muted">
              {featuredInvestment.summary}
            </p>
            <div>
              <a
                href={`/inwestycje/${featuredInvestment.slug}/`}
                class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90"
              >
                Zobacz listę mieszkań
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
