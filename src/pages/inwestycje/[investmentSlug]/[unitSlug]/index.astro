---
import { getInvestments } from '../../../../lib/content';

/** Old unit detail URLs redirect to the investment page (details live in the side sheet). */
export async function getStaticPaths() {
  const investments = await getInvestments();
  return investments.flatMap((investment) =>
    investment.units.map((unit) => ({
      params: {
        investmentSlug: investment.slug,
        unitSlug: unit.slug,
      },
      props: {
        investmentSlug: investment.slug,
      },
    })),
  );
}

const { investmentSlug } = Astro.props;
return Astro.redirect(`/inwestycje/${investmentSlug}/`, 301);
---
