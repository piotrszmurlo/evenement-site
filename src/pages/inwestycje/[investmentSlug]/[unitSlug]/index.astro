---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Banner from '../../../../components/Banner.astro';
import { mockInvestment } from '../../../../data/mock-investments';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  const investment = mockInvestment;
  return investment.units.map((unit) => ({
    params: {
      investmentSlug: investment.slug,
      unitSlug: unit.slug,
    },
    props: {
      unit,
      investmentName: investment.name,
      investmentSlug: investment.slug,
    },
  }));
}

const { unit, investmentName, investmentSlug } = Astro.props;
const currentPrice = unit.priceHistory[unit.priceHistory.length - 1];
---

<BaseLayout title={`Dom ${unit.unitNumber} - ${investmentName}`} description={unit.shortDescription}>
  <Header slot="header" />

  <Banner title={`Dom ${unit.unitNumber}`} />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav class="mb-8 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-text-muted">
          <li><a href="/" class="hover:text-primary transition-colors">Główna</a></li>
          <li>/</li>
          <li><a href="/inwestycje/" class="hover:text-primary transition-colors">Inwestycje</a></li>
          <li>/</li>
          <li><a href={`/inwestycje/${investmentSlug}/`} class="hover:text-primary transition-colors">{investmentName}</a></li>
          <li>/</li>
          <li class="font-semibold text-text">Dom {unit.unitNumber}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 gap-8 items-start lg:grid-cols-2 lg:gap-14">
        <div class="space-y-4">
          <div class="overflow-hidden rounded-lg shadow-lg">
            <Image
              src={unit.mainImage}
              alt={`Dom ${unit.unitNumber}`}
              width={800}
              height={600}
              class="w-full object-cover"
            />
          </div>
        </div>

        <div class="space-y-6">
          <div class="flex items-baseline justify-between border-b border-border pb-4">
            <div>
              <span class="text-topper font-bold uppercase tracking-widest text-accent">{investmentName}</span>
              <h2 class="font-heading text-h2 font-bold uppercase text-text">Dom {unit.unitNumber}</h2>
            </div>
            <span class:list={[
              'rounded-full px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-white',
              unit.status === 'available' ? 'bg-green-600' :
              unit.status === 'reserved' ? 'bg-amber-600' : 'bg-red-600'
            ]}>
              {unit.status === 'available' ? 'Dostępne' :
               unit.status === 'reserved' ? 'Rezerwacja' : 'Sprzedane'}
            </span>
          </div>

          <div class="grid grid-cols-2 gap-4 border-b border-border pb-6">
            <div>
              <p class="text-xs uppercase tracking-wider text-text-muted">Typ nieruchomości</p>
              <p class="text-base font-semibold text-text">{unit.propertyType}</p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-text-muted">Powierzchnia użytkowa</p>
              <p class="text-base font-semibold text-text">{unit.usableAreaM2} m²</p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-text-muted">Liczba pokoi</p>
              <p class="text-base font-semibold text-text">{unit.rooms}</p>
            </div>
            {unit.plotAreaM2 && (
              <div>
                <p class="text-xs uppercase tracking-wider text-text-muted">Działka</p>
                <p class="text-base font-semibold text-text">{unit.plotAreaM2} m²</p>
              </div>
            )}
          </div>

          <div class="space-y-2">
            <h3 class="font-heading text-lg font-bold uppercase tracking-wide text-text">Opis domu</h3>
            <p class="text-sm leading-relaxed text-text-muted">{unit.description}</p>
          </div>

          <div class="rounded-lg border border-border bg-surface p-6">
            <p class="mb-1 text-xs uppercase tracking-wider text-text-muted">Cena ofertowa</p>
            <div class="mb-2 text-2xl font-bold text-text">
              {currentPrice ? `${currentPrice.baseTotalPrice.toLocaleString('pl-PL')} zł` : 'Cena na zapytanie'}
            </div>
            {currentPrice && (
              <p class="text-xs text-text-muted">
                Cena za m²: <strong class="text-text">{currentPrice.pricePerM2.toLocaleString('pl-PL')} zł/m²</strong> (w tym VAT)
              </p>
            )}
            <div class="mt-4 pt-4 border-t border-border">
              <a
                href="/kontakt/"
                class="inline-flex min-h-[44px] w-full items-center justify-center rounded-md bg-accent px-5 py-2.5 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
              >
                Zapytaj o ten dom
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-16 border-t border-border pt-12">
        <h3 class="mb-6 font-heading text-h3 font-bold uppercase text-text">Historia ceny ofertowej</h3>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border text-left">
            <thead>
              <tr class="bg-surface">
                <th class="border border-border px-4 py-3 text-xs font-semibold uppercase tracking-wider text-text">Data obowiązywania</th>
                <th class="border border-border px-4 py-3 text-xs font-semibold uppercase tracking-wider text-text">Cena za m²</th>
                <th class="border border-border px-4 py-3 text-xs font-semibold uppercase tracking-wider text-text">Cena całkowita</th>
                <th class="border border-border px-4 py-3 text-xs font-semibold uppercase tracking-wider text-text">Uwagi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border text-sm text-text-muted">
              {unit.priceHistory.length > 0 ? (
                unit.priceHistory.slice().reverse().map((entry) => (
                  <tr>
                    <td class="border border-border px-4 py-3 font-medium text-text">{entry.validFrom}</td>
                    <td class="border border-border px-4 py-3">{entry.pricePerM2.toLocaleString('pl-PL')} zł/m²</td>
                    <td class="border border-border px-4 py-3 font-semibold text-text">{entry.baseTotalPrice.toLocaleString('pl-PL')} zł</td>
                    <td class="border border-border px-4 py-3 text-xs italic">{entry.note || 'Brak uwag'}</td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td class="border border-border px-4 py-3" colspan="4">
                    Cena i historia cenowa nie zostały jeszcze opublikowane dla tej inwestycji.
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-xs text-text-muted">
          * Zgodnie z wymogami prawnymi prezentujemy historyczne ceny ofertowe powyższego domu.
        </p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
