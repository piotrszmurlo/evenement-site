---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ImagePlaceholder from '../../../components/ImagePlaceholder.astro';
import UnitAvailabilityTable from '../../../components/UnitAvailabilityTable.astro';
import { Image } from 'astro:assets';
import { brand } from '../../../config/brand';
import { getInvestments } from '../../../lib/content';
import { renderBasehubRichText } from '../../../lib/basehub-rich-text';
import {
  buildInvestmentJsonLd,
  investmentImageAlt,
  investmentLocationIntro,
  investmentSeoDescription,
  investmentSeoTitle,
} from '../../../lib/investment-seo';

export async function getStaticPaths() {
  const investments = await getInvestments();
  return investments.map((investment) => ({
    params: { investmentSlug: investment.slug },
    props: { investment },
  }));
}

const { investment } = Astro.props;
const galleryImages = investment.gallery;
const investmentDescriptionHtml = renderBasehubRichText(investment.description);
const salesLabel = investment.salesStatus === 'active' ? 'W sprzedaży' : 'Zakończona';
const mapEmbedUrl = investment.mapEmbedUrl;
const mapLink = investment.mapLink;
const siteURL = Astro.site ?? brand.url;
const pageURL = new URL(Astro.url.pathname, siteURL).href;
const pageTitle = investmentSeoTitle(investment);
const pageDescription = investmentSeoDescription(investment);
const coverAlt = investmentImageAlt(investment);
const schema = buildInvestmentJsonLd(investment, pageURL, String(siteURL));
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={investment.coverImage ?? brand.ogImage.path}
  imageAlt={coverAlt}
  schema={schema}
>
  <Header slot="header" />

  <section class="bg-background pb-section pt-8 sm:pt-10">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Okruszki" class="mb-8">
        <ol class="flex flex-wrap items-center gap-1.5 text-sm text-text-muted">
          <li><a href="/" class="transition-colors hover:text-primary">Strona główna</a></li>
          <li aria-hidden="true" class="text-border">/</li>
          <li><a href="/inwestycje/" class="transition-colors hover:text-primary">Inwestycje</a></li>
          <li aria-hidden="true" class="text-border">/</li>
          <li class="font-medium text-text" aria-current="page">{investment.name}</li>
        </ol>
      </nav>

      <header class="mb-10 max-w-3xl">
        <p class="topper text-accent">
          {salesLabel}
        </p>
        <h1 class="mt-3 font-heading text-h1 font-semibold tracking-tight text-text">
          {investment.name}
        </h1>
        <p class="mt-4 text-base text-text-muted">
          {mapLink ? (
            <a
              href={mapLink}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-primary"
            >
              {investment.locationAddress}
            </a>
          ) : (
            investment.locationAddress
          )}
        </p>
        {investment.summary && (
          <p class="mt-4 text-base leading-relaxed text-text-muted">
            {investment.summary}
          </p>
        )}
      </header>

      <div class="space-y-16 sm:space-y-20">
        <div>
          {galleryImages.length > 0 ? (
            <div class="embla" data-embla>
              <div class="relative overflow-hidden">
                <div class="embla__viewport overflow-hidden" data-embla-viewport>
                  <div class="embla__container flex touch-pan-y">
                    {galleryImages.map((src, index) => (
                      <div class="embla__slide min-w-0 flex-[0_0_100%] touch-pan-y">
                        <button
                          type="button"
                          class="block w-full touch-pan-y cursor-zoom-in focus:outline-none focus-visible:ring-4 focus-visible:ring-accent/70"
                          data-gallery-open
                          data-index={index}
                          data-src={src}
                          aria-label={`Powiększ zdjęcie ${index + 1}`}
                        >
                          <Image
                            src={src}
                            alt={investmentImageAlt(investment, `zdjęcie ${index + 1}`)}
                            width={1600}
                            height={1000}
                            class="aspect-[16/10] min-h-[min(58vh,560px)] w-full object-cover"
                            loading={index === 0 ? 'eager' : 'lazy'}
                          />
                        </button>
                      </div>
                    ))}
                  </div>
                </div>

                {galleryImages.length > 1 && (
                  <>
                    <button
                      type="button"
                      class="embla__button absolute left-3 top-1/2 z-10 hidden size-10 -translate-y-1/2 items-center justify-center text-primary-fg/80 transition-colors hover:text-primary-fg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-fg/80 sm:left-4 sm:inline-flex"
                      data-embla-prev
                      aria-label="Poprzednie zdjęcie"
                    >
                      <svg class="size-6 drop-shadow-sm" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </button>

                    <button
                      type="button"
                      class="embla__button absolute right-3 top-1/2 z-10 hidden size-10 -translate-y-1/2 items-center justify-center text-primary-fg/80 transition-colors hover:text-primary-fg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-fg/80 sm:right-4 sm:inline-flex"
                      data-embla-next
                      aria-label="Następne zdjęcie"
                    >
                      <svg class="size-6 drop-shadow-sm" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </button>
                  </>
                )}
              </div>

              {galleryImages.length > 1 && (
                <div class="mt-4 flex items-end justify-between gap-4 sm:mt-5">
                  <div class="flex min-w-0 flex-1 gap-3 overflow-x-auto pb-1 [scrollbar-width:thin]" data-embla-thumbs aria-label="Miniatury galerii">
                    {galleryImages.map((src, index) => (
                      <button
                        type="button"
                        class="relative aspect-[4/3] w-24 shrink-0 overflow-hidden opacity-40 transition-opacity hover:opacity-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent sm:w-28"
                        data-embla-thumb
                        data-index={index}
                        aria-label={`Przejdź do zdjęcia ${index + 1}`}
                        aria-pressed={index === 0 ? 'true' : 'false'}
                      >
                        <Image
                          src={src}
                          alt=""
                          aria-hidden="true"
                          width={240}
                          height={180}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      </button>
                    ))}
                  </div>
                  <p
                    class="topper hidden shrink-0 text-text-muted sm:block"
                    data-gallery-caption
                    aria-hidden="true"
                  >
                    1 / {galleryImages.length}
                  </p>
                </div>
              )}
            </div>
          ) : (
            <ImagePlaceholder
              label="Galeria inwestycji pojawi się po dodaniu zdjęć"
              class="aspect-[16/10] min-h-[min(58vh,560px)] w-full"
            />
          )}

          {galleryImages.length > 0 && (
            <dialog
              class="fixed inset-0 z-[100] m-0 h-dvh max-h-none w-dvw max-w-none overflow-hidden bg-dark/90 p-0 text-primary-fg open:block backdrop:bg-dark/65"
              data-gallery-viewer
              aria-label={`Galeria inwestycji ${investment.name}`}
            >
              <div class="fixed inset-0 grid h-dvh w-dvw min-w-0 grid-cols-[minmax(0,1fr)] grid-rows-[auto_1fr_auto]">
                <div class="flex items-center justify-between gap-4 px-4 py-3 sm:px-6">
                  <p class="topper text-primary-fg/70" data-gallery-counter></p>
                  <button
                    type="button"
                    class="inline-flex size-11 items-center justify-center text-primary-fg/80 transition-colors hover:text-primary-fg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-fg/80"
                    data-gallery-close
                    aria-label="Zamknij podgląd"
                  >
                    <svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                  </button>
                </div>

                <div
                  class="relative flex min-h-0 min-w-0 touch-pan-y items-center justify-center overflow-hidden px-4 py-2 sm:px-20"
                  data-gallery-viewer-stage
                >
                  {galleryImages.length > 1 && (
                    <>
                      <button
                        type="button"
                        class="absolute left-2 top-1/2 z-10 hidden size-12 -translate-y-1/2 items-center justify-center text-primary-fg/80 transition-colors hover:text-primary-fg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-fg/80 sm:left-4 sm:inline-flex"
                        data-gallery-prev
                        aria-label="Poprzednie zdjęcie"
                      >
                        <svg class="size-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>

                      <button
                        type="button"
                        class="absolute right-2 top-1/2 z-10 hidden size-12 -translate-y-1/2 items-center justify-center text-primary-fg/80 transition-colors hover:text-primary-fg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-fg/80 sm:right-4 sm:inline-flex"
                        data-gallery-next
                        aria-label="Następne zdjęcie"
                      >
                        <svg class="size-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>
                    </>
                  )}

                  <img
                    src={galleryImages[0]}
                    alt=""
                    class="pointer-events-none h-full w-full select-none object-contain"
                    draggable="false"
                    data-gallery-viewer-image
                  />
                </div>

                <div class="px-4 py-4 sm:px-6">
                  <div class="flex w-full min-w-0 gap-3 overflow-x-auto pb-1 [scrollbar-width:thin]" data-gallery-viewer-thumbs aria-label="Miniatury powiększonej galerii">
                    {galleryImages.map((src, index) => (
                      <button
                        type="button"
                        class="relative aspect-[4/3] w-24 shrink-0 overflow-hidden opacity-40 transition-opacity hover:opacity-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-fg/80 sm:w-28"
                        data-gallery-viewer-thumb
                        data-index={index}
                        aria-label={`Pokaż zdjęcie ${index + 1}`}
                        aria-pressed={index === 0 ? 'true' : 'false'}
                      >
                        <Image
                          src={src}
                          alt=""
                          aria-hidden="true"
                          width={240}
                          height={180}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      </button>
                    ))}
                  </div>
                </div>
              </div>
            </dialog>
          )}
        </div>

        {investmentDescriptionHtml && (
          <div
            class="prose max-w-3xl text-base leading-relaxed text-text-muted prose-headings:font-heading prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-text prose-a:text-accent prose-strong:text-text"
            set:html={investmentDescriptionHtml}
          />
        )}

        {(investment.units.length > 0 || investment.prospectusUrl) && (
          <div>
            {investment.units.length > 0 && <UnitAvailabilityTable units={investment.units} />}

            {investment.prospectusUrl && (
              <div class:list={['flex justify-start', investment.units.length > 0 && 'mt-10']}>
                <a
                  href={investment.prospectusUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-primary gap-2"
                >
                  Prospekt informacyjny
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M7 17L17 7M17 7H9M17 7v8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </div>
            )}
          </div>
        )}

        {mapEmbedUrl && (
          <div class="space-y-5">
            <div class="max-w-2xl">
              <h2 class="font-heading text-h2 font-semibold tracking-tight text-text">Lokalizacja</h2>
              <p class="mt-3 text-base leading-relaxed text-text-muted">
                {investmentLocationIntro(investment)}
              </p>
            </div>
            <div class="overflow-hidden border border-border bg-background">
              <iframe
                title={`Mapa inwestycji ${investment.name}`}
                src={mapEmbedUrl}
                class="aspect-[16/10] w-full border-0"
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              ></iframe>
            </div>
            {mapLink && (
              <a
                href={mapLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-[44px] items-center gap-2 text-sm font-semibold text-text transition-colors hover:text-accent"
              >
                Otwórz w Google Maps
                <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  <script>
    import EmblaCarousel from 'embla-carousel';
    const GALLERY_KEY = '__investmentGalleryCleanup';

    const destroyGallery = () => {
      const root = document.querySelector('[data-embla]');
      const cleanup = root?.[GALLERY_KEY];
      if (typeof cleanup === 'function') cleanup();
    };

    const initGallery = () => {
      const root = document.querySelector('[data-embla]');
      if (!root) return;
      destroyGallery();

      const viewport = root.querySelector('[data-embla-viewport]');
      const prevBtn = root.querySelector('[data-embla-prev]');
      const nextBtn = root.querySelector('[data-embla-next]');
      const thumbs = Array.from(root.querySelectorAll('[data-embla-thumb]'));
      const openBtns = Array.from(root.querySelectorAll('[data-gallery-open]'));
      const caption = root.querySelector('[data-gallery-caption]');
      const viewer = document.querySelector('[data-gallery-viewer]');
      const viewerImage = viewer?.querySelector('[data-gallery-viewer-image]');
      const viewerCounter = viewer?.querySelector('[data-gallery-counter]');
      const viewerCloseBtn = viewer?.querySelector('[data-gallery-close]');
      const viewerPrevBtn = viewer?.querySelector('[data-gallery-prev]');
      const viewerNextBtn = viewer?.querySelector('[data-gallery-next]');
      const viewerThumbs = Array.from(viewer?.querySelectorAll('[data-gallery-viewer-thumb]') ?? []);
      const cleanupFns = [];

      if (!viewport) return;

      const embla = EmblaCarousel(viewport, {
        loop: false,
        align: 'start',
        skipSnaps: false,
        watchDrag: true,
      });
      const imageSources = openBtns
        .map((button) => button.getAttribute('data-src'))
        .filter(Boolean);
      let viewerIndex = 0;
      let lastFocusedElement = null;
      let previousBodyOverflow = '';
      const viewerStage = viewer?.querySelector('[data-gallery-viewer-stage]');
      const SWIPE_THRESHOLD_PX = 50;
      let swipeStartX = 0;
      let swipeStartY = 0;
      let swipeActive = false;

      const setThumbActive = (thumb, active) => {
        thumb.setAttribute('aria-pressed', String(active));
        thumb.classList.toggle('opacity-100', active);
        thumb.classList.toggle('opacity-40', !active);
      };

      const setSelected = () => {
        const selectedIndex = embla.selectedScrollSnap();

        thumbs.forEach((thumb, index) => {
          setThumbActive(thumb, index === selectedIndex);
        });

        if (caption) {
          caption.textContent = `${selectedIndex + 1} / ${imageSources.length || thumbs.length}`;
        }

        const canPrev = embla.canScrollPrev();
        const canNext = embla.canScrollNext();

        if (prevBtn) {
          prevBtn.toggleAttribute('disabled', !canPrev);
          prevBtn.classList.toggle('opacity-40', !canPrev);
          prevBtn.classList.toggle('pointer-events-none', !canPrev);
        }

        if (nextBtn) {
          nextBtn.toggleAttribute('disabled', !canNext);
          nextBtn.classList.toggle('opacity-40', !canNext);
          nextBtn.classList.toggle('pointer-events-none', !canNext);
        }
      };

      const setViewerImage = (index) => {
        if (!viewerImage || imageSources.length === 0) return;

        viewerIndex = (index + imageSources.length) % imageSources.length;
        viewerImage.setAttribute('src', imageSources[viewerIndex]);
        viewerImage.setAttribute('alt', `${viewerIndex + 1}. zdjęcie inwestycji`);

        if (viewerCounter) {
          viewerCounter.textContent = `${viewerIndex + 1} / ${imageSources.length}`;
        }

        viewerThumbs.forEach((thumb, thumbIndex) => {
          setThumbActive(thumb, thumbIndex === viewerIndex);

          if (thumbIndex === viewerIndex && viewer?.open) {
            thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }
        });
      };

      const unlockBodyScroll = () => {
        document.body.style.overflow = previousBodyOverflow;
      };

      const openViewer = (index, trigger) => {
        if (!viewer || typeof viewer.showModal !== 'function') return;

        lastFocusedElement = trigger instanceof HTMLElement ? trigger : null;
        previousBodyOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        setViewerImage(index);
        viewer.showModal();
        viewerCloseBtn?.focus();
      };

      const closeViewer = () => {
        if (!viewer) return;

        if (viewer.open) viewer.close();
        unlockBodyScroll();

        if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus();
          lastFocusedElement = null;
        }
      };

      const showViewerPrev = () => setViewerImage(viewerIndex - 1);
      const showViewerNext = () => setViewerImage(viewerIndex + 1);

      const onViewerClose = () => {
        unlockBodyScroll();
        if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus();
          lastFocusedElement = null;
        }
      };

      const onKeydown = (event) => {
        if (!viewer?.open) return;

        if (event.key === 'ArrowLeft' && imageSources.length > 1) {
          event.preventDefault();
          showViewerPrev();
        }

        if (event.key === 'ArrowRight' && imageSources.length > 1) {
          event.preventDefault();
          showViewerNext();
        }
      };

      const onViewerPointerDown = (event) => {
        if (imageSources.length <= 1) return;
        if (event.target instanceof Element && event.target.closest('button')) return;

        swipeActive = true;
        swipeStartX = event.clientX;
        swipeStartY = event.clientY;
      };

      const onViewerPointerUp = (event) => {
        if (!swipeActive) return;
        swipeActive = false;

        const deltaX = event.clientX - swipeStartX;
        const deltaY = event.clientY - swipeStartY;

        if (Math.abs(deltaX) < SWIPE_THRESHOLD_PX) return;
        if (Math.abs(deltaX) <= Math.abs(deltaY)) return;

        if (deltaX < 0) showViewerNext();
        else showViewerPrev();
      };

      const onViewerPointerCancel = () => {
        swipeActive = false;
      };

      const addListener = (target, eventName, handler, options) => {
        if (!target) return;

        target.addEventListener(eventName, handler, options);
        cleanupFns.push(() => target.removeEventListener(eventName, handler, options));
      };

      thumbs.forEach((thumb, index) => {
        addListener(thumb, 'click', () => embla.scrollTo(index));
      });

      openBtns.forEach((button, index) => {
        addListener(button, 'click', () => {
          const clickAllowed =
            typeof embla.clickAllowed === 'function' ? embla.clickAllowed() : true;

          if (clickAllowed) openViewer(index, button);
        });
      });

      viewerThumbs.forEach((thumb, index) => {
        addListener(thumb, 'click', () => setViewerImage(index));
      });

      addListener(prevBtn, 'click', () => embla.scrollPrev());
      addListener(nextBtn, 'click', () => embla.scrollNext());
      addListener(viewerCloseBtn, 'click', closeViewer);
      addListener(viewerPrevBtn, 'click', showViewerPrev);
      addListener(viewerNextBtn, 'click', showViewerNext);
      addListener(viewerStage, 'pointerdown', onViewerPointerDown);
      addListener(viewerStage, 'pointerup', onViewerPointerUp);
      addListener(viewerStage, 'pointercancel', onViewerPointerCancel);
      addListener(viewerStage, 'pointerleave', onViewerPointerCancel);
      addListener(viewer, 'close', onViewerClose);
      addListener(document, 'keydown', onKeydown);
      embla.on('select', setSelected);
      embla.on('reInit', setSelected);
      setSelected();

      root[GALLERY_KEY] = () => {
        if (viewer?.open) viewer.close();
        unlockBodyScroll();
        cleanupFns.forEach((cleanup) => cleanup());
        embla.destroy();
        delete root[GALLERY_KEY];
      };
    };

    initGallery();
    document.addEventListener('astro:page-load', initGallery);
    document.addEventListener('astro:before-swap', destroyGallery);
  </script>

  <Footer slot="footer" />
</BaseLayout>
