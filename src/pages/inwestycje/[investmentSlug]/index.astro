---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Banner from '../../../components/Banner.astro';
import ImagePlaceholder from '../../../components/ImagePlaceholder.astro';
import { Image } from 'astro:assets';
import { getInvestments } from '../../../lib/content';
import { renderBasehubRichText } from '../../../lib/basehub-rich-text';

export async function getStaticPaths() {
  const investments = await getInvestments();
  return investments.map((investment) => ({
    params: { investmentSlug: investment.slug },
    props: { investment },
  }));
}

const { investmentSlug } = Astro.params;
const { investment } = Astro.props;
const galleryImages = investment.gallery;
const investmentDescriptionHtml = renderBasehubRichText(investment.description);
---

<BaseLayout title={investment.name} description={investment.summary}>
  <Header slot="header" />

  <Banner title={investment.name} />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="space-y-12">
        <div class="overflow-hidden rounded-2xl border border-border bg-background shadow-lg">
          {galleryImages.length > 0 ? (
          <div class="embla" data-embla>
            <div class="relative">
              <div class="embla__viewport overflow-hidden" data-embla-viewport>
                <div class="embla__container flex touch-pan-y">
                  {galleryImages.map((src, index) => (
                    <div class="embla__slide min-w-0 flex-[0_0_100%]">
                      <Image
                        src={src}
                        alt={`${investment.name} - zdjęcie ${index + 1}`}
                        width={1400}
                        height={780}
                        class="aspect-[1400/780] w-full object-cover"
                        loading={index === 0 ? 'eager' : 'lazy'}
                      />
                    </div>
                  ))}
                </div>
              </div>

              {galleryImages.length > 1 && (
                <>
                  <button
                    type="button"
                    class="embla__button absolute left-4 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/20 bg-black/45 text-white shadow-lg backdrop-blur-sm transition-colors hover:bg-black/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/80"
                    data-embla-prev
                    aria-label="Poprzednie zdjęcie"
                  >
                    <svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>

                  <button
                    type="button"
                    class="embla__button absolute right-4 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/20 bg-black/45 text-white shadow-lg backdrop-blur-sm transition-colors hover:bg-black/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/80"
                    data-embla-next
                    aria-label="Następne zdjęcie"
                  >
                    <svg class="size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>
                </>
              )}
            </div>

            {galleryImages.length > 1 && (
              <div class="border-t border-border bg-surface px-4 py-4 sm:px-5">
                <div class="flex gap-3 overflow-x-auto pb-1 [scrollbar-width:thin]" data-embla-thumbs aria-label="Miniatury galerii">
                  {galleryImages.map((src, index) => (
                    <button
                      type="button"
                      class="relative aspect-[4/3] w-20 shrink-0 overflow-hidden rounded-lg border border-border bg-border opacity-70 transition-all hover:opacity-100 sm:w-24"
                      data-embla-thumb
                      data-index={index}
                      aria-label={`Przejdź do zdjęcia ${index + 1}`}
                      aria-pressed={index === 0 ? 'true' : 'false'}
                    >
                      <Image
                        src={src}
                        alt=""
                        aria-hidden="true"
                        width={240}
                        height={180}
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    </button>
                  ))}
                </div>
              </div>
            )}
          </div>
          ) : (
            <ImagePlaceholder label="Galeria inwestycji pojawi się po dodaniu zdjęć" class="aspect-[1400/780] w-full" />
          )}
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.3fr_0.7fr] lg:items-start">
          <div class="space-y-6">
            <span class="text-topper font-bold uppercase tracking-widest text-accent">Inwestycja</span>
            <h2 class="font-heading text-h2 font-bold uppercase text-text">{investment.name}</h2>
            <p class="flex items-center gap-1 text-sm text-text-muted">
              <svg class="size-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {investment.locationAddress}
            </p>
            <div class="prose prose-slate max-w-none text-sm leading-7 text-text-muted" set:html={investmentDescriptionHtml} />
          </div>

          <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
            <h3 class="font-heading text-xl font-bold uppercase text-text">Szybkie informacje</h3>
            <dl class="mt-5 space-y-4 text-sm">
              <div class="flex items-start justify-between gap-4 border-b border-border pb-3">
                <dt class="text-text-muted">Lokale</dt>
                <dd class="font-semibold text-text">{investment.units.length}</dd>
              </div>
              <div class="flex items-start justify-between gap-4 border-b border-border pb-3">
                <dt class="text-text-muted">Status sprzedaży</dt>
                <dd class="font-semibold text-text">
                  {investment.salesStatus === 'active' ? 'Aktywna' : 'Zakończona'}
                </dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-text-muted">Prospekt</dt>
                <dd class="font-semibold text-text">
                  {investment.prospectusUrl ? 'Dostępny' : 'Brak'}
                </dd>
              </div>
            </dl>

            {investment.prospectusUrl && (
              <div class="pt-6">
                <a
                  href={investment.prospectusUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-[44px] w-full items-center justify-center gap-2 rounded-md border border-border bg-background px-5 py-2.5 text-sm font-semibold text-text transition-colors hover:bg-border"
                >
                  <svg class="size-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Pobierz prospekt informacyjny (PDF)
                </a>
              </div>
            )}
          </div>
        </div>

        <div class="border-t border-border pt-12">
          <div class="mb-8">
            <h3 class="font-heading text-h3 font-bold uppercase text-text">Lista dostępnych nieruchomości</h3>
          </div>

          <div class="overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-border text-left text-sm">
                <thead class="bg-surface text-xs uppercase tracking-wider text-text-muted">
                  <tr>
                    <th scope="col" class="px-4 py-3">Budynek</th>
                    <th scope="col" class="px-4 py-3">Pow. budynku</th>
                    <th scope="col" class="px-4 py-3">Pow. działki</th>
                    <th scope="col" class="px-4 py-3">Status</th>
                    <th scope="col" class="px-4 py-3">Cena brutto</th>
                    <th scope="col" class="px-4 py-3">Cena za m²</th>
                    <th scope="col" class="px-4 py-3">Rzuty</th>
                    <th scope="col" class="px-4 py-3">Szczegóły</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border bg-background">
                  {investment.units.map((unit) => {
                    const currentPrice = unit.currentPrice;
                    const statusLabel =
                      unit.status === 'available'
                        ? 'Dostępny'
                        : unit.status === 'reserved'
                          ? 'Rezerwacja'
                          : 'Sprzedany';

                    return (
                      <tr class="align-top">
                        <td class="px-4 py-4 font-semibold text-text">{unit.unitNumber.toUpperCase()}</td>
                        <td class="px-4 py-4 text-text-muted">{unit.usableAreaM2.toLocaleString('pl-PL')} m²</td>
                        <td class="px-4 py-4 text-text-muted">{unit.plotAreaM2.toLocaleString('pl-PL')} m²</td>
                        <td class="px-4 py-4">
                          <span class:list={[
                            'inline-flex rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-white',
                            unit.status === 'available'
                              ? 'bg-green-600'
                              : unit.status === 'reserved'
                                ? 'bg-amber-600'
                                : 'bg-red-600',
                          ]}>
                            {statusLabel}
                          </span>
                        </td>
                        <td class="px-4 py-4 font-semibold text-text">
                          {currentPrice ? `${currentPrice.totalPrice.toLocaleString('pl-PL')} zł` : 'Zapytaj'}
                        </td>
                        <td class="px-4 py-4 font-semibold text-text">
                          {currentPrice ? `${currentPrice.pricePerM2.toLocaleString('pl-PL')} zł` : 'Zapytaj'}
                        </td>
                        <td class="px-4 py-4">
                          <div class="flex flex-col gap-3">
                            {unit.slug === 'a2' && investment.prospectusUrl ? (
                              <a
                                href={investment.prospectusUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-xs font-medium text-primary transition-colors hover:text-primaryLight"
                              >
                                <span aria-hidden="true">i</span>
                                Karta SK2
                              </a>
                            ) : (
                              <span class="text-xs text-text-muted">—</span>
                            )}
                          </div>
                        </td>
                                                <td class="px-4 py-4">
                          <a
                            href={`/inwestycje/${investmentSlug}/${unit.slug}/`}
                            class="inline-flex w-fit items-center rounded border border-border bg-surface px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-text transition-colors hover:bg-border"
                          >
                            Szczegóły
                          </a>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import EmblaCarousel from 'embla-carousel';
    const GALLERY_KEY = '__investmentGalleryCleanup';

    const destroyGallery = () => {
      const root = document.querySelector('[data-embla]');
      const cleanup = root?.[GALLERY_KEY];
      if (typeof cleanup === 'function') cleanup();
    };

    const initGallery = () => {
      const root = document.querySelector('[data-embla]');
      if (!root) return;
      destroyGallery();

      const viewport = root.querySelector('[data-embla-viewport]');
      const prevBtn = root.querySelector('[data-embla-prev]');
      const nextBtn = root.querySelector('[data-embla-next]');
      const thumbs = Array.from(root.querySelectorAll('[data-embla-thumb]'));

      if (!viewport) return;

      const embla = EmblaCarousel(viewport, {
        loop: false,
        align: 'start',
        skipSnaps: false,
      });

      const setSelected = () => {
        const selectedIndex = embla.selectedScrollSnap();

        thumbs.forEach((thumb, index) => {
          const active = index === selectedIndex;
          thumb.setAttribute('aria-pressed', String(active));
          thumb.classList.toggle('border-2', active);
          thumb.classList.toggle('border-primary', active);
          thumb.classList.toggle('opacity-100', active);
          thumb.classList.toggle('opacity-70', !active);
        });

        const canPrev = embla.canScrollPrev();
        const canNext = embla.canScrollNext();

        if (prevBtn) {
          prevBtn.toggleAttribute('disabled', !canPrev);
          prevBtn.classList.toggle('opacity-40', !canPrev);
          prevBtn.classList.toggle('pointer-events-none', !canPrev);
        }

        if (nextBtn) {
          nextBtn.toggleAttribute('disabled', !canNext);
          nextBtn.classList.toggle('opacity-40', !canNext);
          nextBtn.classList.toggle('pointer-events-none', !canNext);
        }
      };

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', () => embla.scrollTo(index));
      });

      prevBtn?.addEventListener('click', () => embla.scrollPrev());
      nextBtn?.addEventListener('click', () => embla.scrollNext());
      embla.on('select', setSelected);
      embla.on('reInit', setSelected);
      setSelected();

      root[GALLERY_KEY] = () => {
        embla.destroy();
        delete root[GALLERY_KEY];
      };
    };

    initGallery();
    document.addEventListener('astro:page-load', initGallery);
    document.addEventListener('astro:before-swap', destroyGallery);
  </script>

  <Footer slot="footer" />
</BaseLayout>
