---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
---

<BaseLayout title="Kontakt" description={`Skontaktuj się z firmą deweloperską ${brand.name}. Dane kontaktowe, adresy biur i rejestrowe.`}>
  <Header slot="header" />

  <Banner title="Kontakt" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">
        
        <!-- Contact details / Company data -->
        <div class="space-y-8">
          <div>
            <span class="text-topper font-bold uppercase tracking-widest text-accent">Dane firmy</span>
            <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">{client.name}</h2>
            <p class="mt-3 text-text-muted leading-relaxed">
              Realizujemy inwestycje mieszkaniowe z dbałością o standardy i terminowość. Zapraszamy do bezpośredniego kontaktu telefonicznego lub mailowego.
            </p>
          </div>

          <!-- Registration Numbers -->
          <div class="rounded-lg border border-border bg-surface p-6">
            <h3 class="font-heading text-lg font-semibold text-text mb-4">Informacje rejestrowe</h3>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><strong class="text-text">Forma prawna:</strong> {client.legalForm}</li>
              <li><strong class="text-text">KRS:</strong> {client.krs}</li>
              <li><strong class="text-text">NIP:</strong> {client.nip}</li>
              <li><strong class="text-text">REGON:</strong> {client.regon}</li>
            </ul>
          </div>

          <!-- Fast contact -->
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="flex size-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">Telefon</p>
                <a href={`tel:${client.phoneForTel}`} class="text-lg font-bold text-text hover:text-primary transition-colors">
                  {client.phoneFormatted}
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="flex size-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">E-mail</p>
                <a href={`mailto:${client.email}`} class="text-lg font-bold text-text hover:text-primary transition-colors">
                  {client.email}
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Addresses -->
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-1">
          
          <!-- Registered Address -->
          <div class="rounded-lg border border-border bg-background p-6 shadow-sm">
            <h3 class="font-heading text-xl font-bold text-text uppercase tracking-wide">Siedziba firmy</h3>
            <p class="mt-3 text-text-muted leading-relaxed">
              {client.name}<br />
              {client.address.lineOne}<br />
              {client.address.zip} {client.address.city}
            </p>
            <div class="mt-4">
              <a href={client.address.mapLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-primary-light transition-colors">
                Zobacz na mapie &rarr;
              </a>
            </div>
          </div>

          <!-- Sales Office Address -->
          <div class="rounded-lg border border-border bg-background p-6 shadow-sm">
            <h3 class="font-heading text-xl font-bold text-text uppercase tracking-wide">Biuro sprzedaży</h3>
            <p class="mt-3 text-text-muted leading-relaxed">
              {client.salesOffice.lineOne}<br />
              {client.salesOffice.zip} {client.salesOffice.city}
            </p>
            <div class="mt-4">
              <a href={client.salesOffice.mapLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-primary-light transition-colors">
                Zobacz na mapie &rarr;
              </a>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
