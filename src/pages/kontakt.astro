---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import { brand } from "../config/brand";
import { getDeveloperContact } from "../lib/content";

const contact = await getDeveloperContact();
---

<BaseLayout
  title="Kontakt"
  description={`Skontaktuj się z firmą deweloperską ${brand.name}. Dane kontaktowe, adresy biur i rejestrowe.`}
>
  <Header slot="header" />

  <Banner title="Kontakt" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Contact details / Company data -->
        <div class="space-y-8">
          <div>
            <span
              class="text-topper font-bold uppercase tracking-widest text-accent"
              >Dane firmy</span
            >
            <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">
              {contact.name}
            </h2>
          </div>

          <!-- Company Details & Registration Info -->
          <div class="rounded-lg border border-border bg-surface p-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <h3 class="font-heading text-base font-semibold text-text mb-3">
                  Siedziba firmy
                </h3>
                <p class="text-sm text-text-muted leading-relaxed">
                  {contact.name}<br />
                  {contact.registeredAddress.lineOne}<br />
                  {contact.registeredAddress.lineTwo}
                </p>
              </div>
              <div>
                <h3 class="font-heading text-base font-semibold text-text mb-3">
                  Informacje rejestrowe
                </h3>
                <ul class="space-y-2 text-sm text-text-muted">
                  {contact.legalForm && (
                    <li>
                      <strong class="text-text">Forma prawna:</strong><br />
                      {contact.legalForm}
                    </li>
                  )}
                  {contact.nip && (
                    <li>
                      <strong class="text-text">NIP:</strong>
                      {contact.nipFormatted ?? contact.nip}
                    </li>
                  )}
                  {contact.regon && (
                    <li>
                      <strong class="text-text">REGON:</strong>
                      {contact.regon}
                    </li>
                  )}
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Fast contact -->
        <div class="flex flex-col justify-center space-y-8 lg:pl-8">
          <div>
            <span
              class="text-topper font-bold uppercase tracking-widest text-accent"
              >Kontakt</span
            >
            <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">
              Skontaktuj się
            </h2>
          </div>

          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div
                class="flex size-12 items-center justify-center rounded-lg bg-primary/10 text-primary"
              >
                <svg
                  class="size-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-wider text-text-muted"
                >
                  Telefon
                </p>
                <a
                  href={`tel:${contact.phoneHref}`}
                  class="text-lg font-bold text-text hover:text-primary transition-colors"
                >
                  {contact.phoneFormatted}
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div
                class="flex size-12 items-center justify-center rounded-lg bg-primary/10 text-primary"
              >
                <svg
                  class="size-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-wider text-text-muted"
                >
                  E-mail
                </p>
                <a
                  href={`mailto:${contact.email}`}
                  class="text-lg font-bold text-text hover:text-primary transition-colors"
                >
                  {contact.email}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
