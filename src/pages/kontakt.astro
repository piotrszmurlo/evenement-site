---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { brand } from "../config/brand";
import { client } from "../data/client";
import { getDeveloperContact } from "../lib/content";

const contact = await getDeveloperContact();
const salesOfficeMapHref = client.salesOffice.mapLink;
const partner = client.salesPartner;
---

<BaseLayout
  title="Kontakt"
  description={`Zadzwoń do ${brand.name}. Biuro sprzedaży DoktorDom.pl, dane kontaktowe i adres.`}
>
  <Header slot="header" />

  <section
    class="bg-dark text-primary-fg"
    aria-labelledby="kontakt-heading"
  >
    <div class="mx-auto max-w-site px-4 pb-16 pt-14 sm:px-6 sm:pb-20 sm:pt-16 lg:pb-24 lg:pt-20">
      <div class="kontakt-rise space-y-8">
        <div class="max-w-2xl space-y-8">
          <h1
            id="kontakt-heading"
            class="font-heading text-[clamp(2.5rem,1rem+6vw,4.25rem)] font-semibold leading-[1.05] tracking-tight text-primary-fg"
          >
            Zadzwoń do nas
          </h1>

          <p class="max-w-md text-lead leading-relaxed text-primary-fg/75">
            Porozmawiajmy o Twoim wymarzonym domu — chętnie odpowiemy na pytania
            i umówimy spotkanie.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 sm:gap-12 lg:gap-16">
          <div class="space-y-4">
            <div>
              <p class="topper text-primary-fg/65">
                Osoba odpowiedzialna za sprzedaż
              </p>
              <p class="mt-2 text-xl font-semibold tracking-tight text-primary-fg sm:text-2xl">
                {partner.personName}
              </p>
            </div>

            <a
              href={`tel:${partner.phone}`}
              class="btn-accent"
            >
              {partner.phoneFormatted}
            </a>

            <a
              href={`mailto:${partner.email}`}
              class="block text-lg font-semibold tracking-tight text-primary-fg underline-offset-4 transition-colors hover:text-accent hover:underline sm:text-xl"
            >
              {partner.email}
            </a>
          </div>

          <div class="space-y-4">
            <div>
              <p class="topper text-primary-fg/65">
                Deweloper
              </p>
              <p class="mt-2 text-xl font-semibold tracking-tight text-primary-fg sm:text-2xl">
                Marek Szmurło
              </p>
            </div>

            <a
              href={`tel:${contact.phoneHref}`}
              class="block text-lg font-semibold tracking-tight text-primary-fg underline-offset-4 transition-colors hover:text-accent hover:underline sm:text-xl"
            >
              {contact.phoneFormatted}
            </a>

            <a
              href={`mailto:${contact.email}`}
              class="block text-lg font-semibold tracking-tight text-primary-fg underline-offset-4 transition-colors hover:text-accent hover:underline sm:text-xl"
            >
              {contact.email}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-section" aria-labelledby="visit-heading">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:items-start lg:gap-16">
        <div class="lg:col-span-5">
          <p class="topper text-accent">Biuro sprzedaży</p>
          <h2
            id="visit-heading"
            class="mt-3 font-heading text-h2 font-semibold tracking-tight text-text"
          >
            {partner.name}
          </h2>
          <p class="mt-4 max-w-sm text-lead leading-relaxed text-text-muted">
            Kompleksowa obsługa sprzedaży — od wyboru domu przez kredyt
            i wszystkie formalności.
          </p>

          <div class="mt-8">
            <p class="topper text-text-muted">Pomagamy w zakupie</p>
            <ul class="mt-4 space-y-5">
              {
                partner.services.map((service) => (
                  <li>
                    <p class="text-base font-medium text-text">{service.title}</p>
                    <p class="mt-1 text-sm text-text-muted">{service.note}</p>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="space-y-10 lg:col-span-7 lg:border-l lg:border-border lg:pl-16">
          <div>
            <p class="topper text-text-muted">Adres</p>
            <p class="mt-2 font-heading text-h3 font-semibold tracking-tight text-text">
              {contact.salesOfficeAddress.lineOne}
            </p>
            <p class="mt-2 text-lead text-text-muted">
              {contact.salesOfficeAddress.lineTwo}
            </p>
            <a
              href={salesOfficeMapHref}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary mt-6"
            >
              Otwórz w mapach
            </a>
          </div>

          <div>
            <img
              src={partner.logoSrc}
              alt={partner.logoAlt}
              width="400"
              height="178"
              class="h-auto w-full max-w-[380px] border border-border bg-white p-4"
              decoding="async"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background py-section" aria-labelledby="company-heading">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <h2
        id="company-heading"
        class="font-heading text-h3 font-semibold tracking-tight text-text"
      >
        Dane dewelopera
      </h2>

      <div class="mt-8 max-w-2xl space-y-6">
        <div>
          <p class="font-heading text-h3 font-semibold tracking-tight text-text">
            {contact.name}
          </p>
          {
            contact.legalForm && (
              <p class="mt-2 text-base text-text-muted">{contact.legalForm}</p>
            )
          }
        </div>

        <div>
          <p class="topper text-text-muted">
            Siedziba
          </p>
          <p class="mt-2 text-base text-text">
            {contact.registeredAddress.lineOne}
            {
              contact.registeredAddress.lineTwo && (
                <>
                  <br />
                  {contact.registeredAddress.lineTwo}
                </>
              )
            }
          </p>
        </div>

        <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            contact.nip && (
              <div>
                <dt class="topper text-text-muted">
                  NIP
                </dt>
                <dd class="mt-2 text-base text-text">
                  {contact.nipFormatted ?? contact.nip}
                </dd>
              </div>
            )
          }
          {
            contact.regon && (
              <div>
                <dt class="topper text-text-muted">
                  REGON
                </dt>
                <dd class="mt-2 text-base text-text">{contact.regon}</dd>
              </div>
            )
          }
        </dl>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @keyframes kontakt-rise {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .kontakt-rise {
    animation: kontakt-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .kontakt-rise {
      animation: none;
    }
  }
</style>
