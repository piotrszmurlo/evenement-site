---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { Image } from 'astro:assets';
import { renderBasehubRichText } from '../lib/basehub-rich-text';
import { getAboutPageContent } from '../lib/content';

const aboutPage = await getAboutPageContent();
const storyImageUrl = aboutPage.storyImage?.url;
const storyContentHtml = renderBasehubRichText(aboutPage.storyContent);
const pageDescription = 'Dowiedz się więcej o firmie EVENEMENT, naszej historii, wartościach i podejściu do realizacji inwestycji mieszkaniowych.';
---

<BaseLayout title="O nas" description={pageDescription}>
  <Header slot="header" />

  <!-- Story -->
  <section class="pb-section pt-10 sm:pt-14">
    <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">
      <div class="overflow-hidden rounded-lg shadow-lg">
        {storyImageUrl && (
          <Image
            src={storyImageUrl}
            alt="Zdjęcie ilustracyjne"
            width={800}
            height={600}
            loading="lazy"
            class="size-full object-cover"
          />
        )}
      </div>
      <div class="space-y-5">
        <span class="topper text-accent">{aboutPage.storyEyebrow}</span>
        <h1 class="font-heading text-h2 font-bold uppercase text-text">{aboutPage.storyHeading}</h1>
        <div class="prose max-w-none text-text-muted prose-headings:text-text prose-a:text-accent prose-strong:text-text" set:html={storyContentHtml} />
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
